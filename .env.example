# Copiá este archivo a .env y completá los valores.
# yfinance y World Bank NO requieren clave.

# --- FRED (macro de EE.UU.) — OBLIGATORIA si usás variables macro ---
# Conseguila gratis en: https://fredaccount.stlouisfed.org/apikeys
FRED_API_KEY=

# --- Anthropic (capa de explicación / LLM) — OBLIGATORIA para el resumen ---
# Conseguila en: https://console.anthropic.com/  (sección API Keys)
ANTHROPIC_API_KEY=
# Modelo configurable. Default: claude-opus-4-8 (máxima calidad).
# Para bajar costo en alto volumen, podés usar claude-sonnet-4-6.
ANTHROPIC_MODEL=claude-opus-4-8

# --- SEC EDGAR (fundamentals) — OBLIGATORIO el User-Agent con tu email ---
# La SEC EXIGE identificarte. Formato: "Nombre Apellido email@dominio.com"
SEC_USER_AGENT=Tu Nombre tu_email@ejemplo.com

# --- Ventana de datos (opcional; default = últimos 5 años) ---
# START_DATE=2020-01-01
# END_DATE=2025-01-01

# --- Cache (opcional) ---
# CACHE_DIR=.cache
